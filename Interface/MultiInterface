public interface MultiInterface {
    void print();
}

interface Showable {
    void show();
}

class Demo implements MultiInterface, Showable {

    public void print() {
        System.out.println("Printing...");
    }

    public void show() {
        System.out.println("Showing...");
    }
}
public class InterfaceMain {
	    public static void main(String[] args) {
	        Demo obj = new Demo();
	        obj.print();
	        obj.show();
	    }
	}

