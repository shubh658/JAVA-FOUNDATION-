
public interface Shape {
	    void area();
	}

	class Circle implements Shape {
	    double radius = 5;

	    public void area() {
	        double result = 3.14 * radius * radius;
	        System.out.println("Area of Circle: " + result);
	    }
	}


public class Interface {
	    public static void main(String[] args) {
	        Circle c = new Circle();
	        c.area();
	    }
	}

